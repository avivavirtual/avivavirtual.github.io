# Database and cache
DATABASE_URL=postgresql://postgres:password@localhost:5432/avivavirtual
REDIS_URL=redis://localhost:6379

# JWT auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI and AI settings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_CONFIDENCE_THRESHOLD=0.6
AI_LOCAL_MODE=false
OLLAMA_BASE_URL=http://localhost:11434

# Frontend / API URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WIDGET_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
PORT=3001

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@avivavirtual.ca
SMTP_PASS=change_this

# AWS S3 uploads
AWS_S3_BUCKET=avivavirtual-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1

# VoIP placeholders
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
VOIPMS_USERNAME=placeholder
VOIPMS_PASSWORD=placeholder

# Runtime environment
NODE_ENV=development
