# ---------- Database / Cache ----------
DATABASE_URL=postgresql://postgres:password@postgres:5432/avivavirtual
REDIS_URL=redis://redis:6379

# ---------- JWT ----------
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---------- Frontend / Widget ----------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WIDGET_URL=http://localhost:3000/widget/avivavirtual-widget.js
CORS_ORIGIN=http://localhost:3000

# ---------- SMTP ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@avivavirtual.ca
SMTP_PASS=change_this

# ---------- AWS S3 ----------
AWS_S3_BUCKET=avivavirtual-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1

# ---------- Telephony Placeholders ----------
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
VOIPMS_USERNAME=placeholder
VOIPMS_PASSWORD=placeholder

# ---------- Docker Compose DB Bootstrap ----------
POSTGRES_DB=avivavirtual
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
