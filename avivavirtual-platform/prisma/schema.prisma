generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  SUPER_ADMIN
  CLIENT_ADMIN
  AGENT
  CUSTOMER
}

enum UserStatusType {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ConversationStatusType {
  OPEN
  ASSIGNED
  PENDING
  RESOLVED
  CLOSED
}

enum ChannelType {
  CHAT
  EMAIL
  VOICE
  SMS
}

enum LanguageType {
  EN
  FR
}

enum SenderType {
  AGENT
  CUSTOMER
  SYSTEM
}

enum TicketPriorityType {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatusType {
  NEW
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum KnowledgeBaseStatusType {
  DRAFT
  APPROVED
  ARCHIVED
}

enum FileProcessingStatusType {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum AgentAvailabilityType {
  AVAILABLE
  BUSY
  OFFLINE
}

enum CallbackStatusType {
  NEW
  SCHEDULED
  COMPLETED
  CANCELED
}

enum PlanType {
  STARTER
  GROWTH
  ENTERPRISE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           Role
  organizationId String?
  status         UserStatusType  @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assignedConversations Conversation[] @relation("ConversationAssignedAgent")
  assignedTickets Ticket[]       @relation("TicketAssignedAgent")
  ticketComments TicketComment[]
  notifications  Notification[]
  agentStatus    AgentStatus?
  auditLogs      AuditLog[]
  callRecords    CallRecord[]    @relation("CallRecordAgent")

  @@index([organizationId])
}

model Organization {
  id             String                @id @default(cuid())
  name           String
  plan           PlanType              @default(STARTER)
  logoUrl        String?
  brandColor     String?
  createdAt      DateTime              @default(now())

  users          User[]
  customers      Customer[]
  conversations  Conversation[]
  tickets        Ticket[]
  kbArticles     KnowledgeBaseArticle[]
  kbFiles        KnowledgeBaseFile[]
  auditLogs      AuditLog[]
  slaConfigs     SLAConfig[]
  clientSettings ClientSettings?
  aiSettings     AISettings?
  callRecords    CallRecord[]
  callbacks      CallbackRequest[]
}

model Customer {
  id             String          @id @default(cuid())
  name           String
  email          String
  phone          String?
  organizationId String
  createdAt      DateTime        @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  tickets        Ticket[]
  callRecords    CallRecord[]
  callbacks      CallbackRequest[]

  @@index([organizationId])
  @@index([email])
}

model Conversation {
  id              String                 @id @default(cuid())
  customerId      String
  organizationId  String
  status          ConversationStatusType @default(OPEN)
  channel         ChannelType            @default(CHAT)
  assignedAgentId String?
  language        LanguageType           @default(EN)
  createdAt       DateTime               @default(now())
  closedAt        DateTime?

  customer        Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent   User?                  @relation("ConversationAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  messages        Message[]

  @@index([organizationId])
  @@index([customerId])
  @@index([assignedAgentId])
}

model Message {
  id              String          @id @default(cuid())
  conversationId  String
  senderType      SenderType
  content         String
  isAI            Boolean         @default(false)
  confidenceScore Float?
  createdAt       DateTime        @default(now())

  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Ticket {
  id              String             @id @default(cuid())
  organizationId  String
  customerId      String
  assignedAgentId String?
  title           String
  description     String?
  priority        TicketPriorityType @default(MEDIUM)
  status          TicketStatusType   @default(NEW)
  slaDeadline     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedAgent   User?              @relation("TicketAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  comments        TicketComment[]

  @@index([organizationId])
  @@index([customerId])
  @@index([assignedAgentId])
}

model TicketComment {
  id         String    @id @default(cuid())
  ticketId   String
  authorId   String
  content    String
  isInternal Boolean   @default(true)
  createdAt  DateTime  @default(now())

  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
}

model KnowledgeBaseArticle {
  id             String                  @id @default(cuid())
  organizationId String
  title          String
  content        String
  status         KnowledgeBaseStatusType @default(DRAFT)
  tags           String[]
  version        Int                     @default(1)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  embeddings     Embedding[]

  @@index([organizationId])
}

model KnowledgeBaseFile {
  id               String                   @id @default(cuid())
  organizationId   String
  filename         String
  fileType         String
  storageUrl       String
  processingStatus FileProcessingStatusType @default(UPLOADED)
  createdAt        DateTime                 @default(now())

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Embedding {
  id         String    @id @default(cuid())
  articleId  String
  vector     Unsupported("vector(1536)")
  chunkText  String
  createdAt  DateTime  @default(now())

  article    KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model AgentStatus {
  id        String                @id @default(cuid())
  agentId   String                @unique
  status    AgentAvailabilityType @default(AVAILABLE)
  updatedAt DateTime              @updatedAt

  agent     User                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  action         String
  resource       String
  metadata       Json?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SLAConfig {
  id                    String             @id @default(cuid())
  organizationId        String
  priority              TicketPriorityType
  responseTimeMinutes   Int
  resolutionTimeMinutes Int

  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, priority])
  @@index([organizationId])
}

model ClientSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  supportHours      Json?
  escalationRules   Json?
  preferredLanguage LanguageType @default(EN)
  widgetEnabled     Boolean      @default(true)

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AISettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  model                String       @default("gpt-4o")
  confidenceThreshold  Float        @default(0.6)
  maxTokens            Int          @default(700)
  systemPromptOverride String?

  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CallRecord {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  agentId        String?
  duration       Int
  summary        String?
  recordingUrl   String?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent          User?        @relation("CallRecordAgent", fields: [agentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
  @@index([agentId])
}

model CallbackRequest {
  id             String             @id @default(cuid())
  organizationId String
  customerId     String
  phone          String
  preferredTime  DateTime?
  status         CallbackStatusType @default(NEW)
  createdAt      DateTime           @default(now())

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
}

model SubscriptionPlan {
  id               String   @id @default(cuid())
  name             String   @unique
  maxAgents        Int
  maxConversations Int
  priceMonthly     Decimal  @db.Decimal(10, 2)
  features         String[]
}
