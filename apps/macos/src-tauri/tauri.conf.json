{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Avivavirtual Agent",
  "version": "1.0.0",
  "identifier": "ca.avivavirtual.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Avivavirtual Agent",
        "width": 1280,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": []
  }
}
