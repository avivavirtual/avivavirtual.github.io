# App
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
WEB_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database (asyncpg format)
DATABASE_URL=postgresql+asyncpg://aviva_user:aviva_password@localhost:5432/avivavirtual_db

# Postgres (used by docker-compose to configure the postgres container;
# keep these in sync with the credentials in DATABASE_URL above)
POSTGRES_DB=avivavirtual_db
POSTGRES_USER=aviva_user
POSTGRES_PASSWORD=aviva_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT - generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# Security - generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_CONFIDENCE_THRESHOLD=0.75

# Whisper: "openai" (default) or "self-hosted"
WHISPER_PROVIDER=openai
WHISPER_SELF_HOSTED_URL=http://localhost:8000
WHISPER_API_SECRET=
OPENAI_WHISPER_MODEL=whisper-1
MAX_AUDIO_SIZE_MB=25
STORE_CALL_RECORDINGS=true
RECORDING_STORAGE_PATH=./recordings

# Storage: "local" or "r2"
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
CF_R2_ENDPOINT=
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=
CF_R2_PUBLIC_URL=
CF_R2_RECORDINGS_BUCKET=

# VoIP.ms
VOIPMS_API_USERNAME=your@email.com
VOIPMS_API_PASSWORD=your_voipms_api_password
VOIPMS_DID=your_10_digit_did
VOIPMS_SIP_SERVER=toronto.voip.ms
VOIPMS_WEBRTC_SERVER=webrtc.voip.ms
VOIPMS_ACCOUNT=your_main_account_number
VOIPMS_SIP_PASSWORD=your_sip_password

# Email (Brevo SMTP)
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Avivavirtual <support@avivavirtual.ca>

# PIPEDA data retention
RECORDING_RETAIN_DAYS=90
TRANSCRIPTION_RETAIN_DAYS=365
